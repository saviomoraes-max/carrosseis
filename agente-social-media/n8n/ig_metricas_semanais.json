      "id": "b2000000-0000-4000-8000-000000000006",
      "name": "Buscar Série de Seguidores",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Série diária de novos seguidores: 1 linha por dia.\n// end_time da Meta marca o FIM do período (madrugada do dia seguinte) —\n// subtrai 1 dia pra gravar a data do dia a que o valor se refere.\nconst serie = ($input.first().json.data || [])[0]?.values || [];\nreturn serie.map((v) => ({\n  json: {\n    metric_date: new Date(Date.parse(v.end_time) - 86400000).toISOString().slice(0, 10),\n    metric: 'follower_count',\n    value: v.value ?? null,\n  },\n}));"
      },
      "id": "b2000000-0000-4000-8000-000000000007",
      "name": "Achatar Seguidores",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
