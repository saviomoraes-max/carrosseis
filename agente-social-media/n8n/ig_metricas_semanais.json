      "id": "b2000000-0000-4000-8000-000000000003",
      "name": "Buscar Insights da Conta 7d",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, -200],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
