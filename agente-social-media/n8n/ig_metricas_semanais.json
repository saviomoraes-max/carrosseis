    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Transforma a resposta agregada de 7 dias em linhas (metric_date, metric, value).\n// Métricas semanais levam sufixo _7d pra não misturar com séries diárias.\nconst hoje = new Date().toISOString().slice(0, 10);\nconst dados = $input.first().json.data || [];\nreturn dados.map((m) => ({\n  json: {\n    metric_date: hoje,\n    metric: `${m.name}_7d`,\n    value: m.total_value?.value ?? m.values?.[0]?.value ?? null,\n  },\n}));"
      },
      "id": "b2000000-0000-4000-8000-000000000004",
      "name": "Achatar Insights 7d",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, -200]
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": {
          "__rl": true,
          "value": "public",
          "mode": "list"
        },
        "table": {
          "__rl": true,
          "value": "ig_account_insights_daily",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "metric_date": "={{ $json.metric_date }}",
            "metric": "={{ $json.metric }}",
            "value": "={{ $json.value }}"
          }
        },
        "options": {
          "skipOnConflict": true
        }
      },
      "id": "b2000000-0000-4000-8000-000000000005",
      "name": "Gravar Insights da Conta",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
