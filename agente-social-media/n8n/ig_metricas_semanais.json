    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Define a lista de métricas conforme o tipo de mídia (reels tem métricas próprias).\nconst base = 'views,reach,likes,comments,saved,shares,total_interactions';\nconst metricas = $json.media_product_type === 'REELS'\n  ? `${base},ig_reels_avg_watch_time`\n  : base;\nreturn { json: { ...$json, metricas } };"
      },
      "id": "b2000000-0000-4000-8000-000000000013",
      "name": "Montar Lista de Métricas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 320]
    },
    {
      "parameters": {
        "url": "=https://graph.facebook.com/v23.0/{{ $json.id }}/insights",
        "sendQuery": true,
        "queryParameters": {
