            {
              "name": "metric",
              "value": "reach,views,accounts_engaged,total_interactions,profile_links_taps"
            },
            {
              "name": "period",
              "value": "day"
            },
            {
              "name": "metric_type",
              "value": "total_value"
            },
            {
              "name": "since",
              "value": "={{ $now.minus({ days: 7 }).toUnixInteger() }}"
            },
            {
              "name": "until",
              "value": "={{ $now.toUnixInteger() }}"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
