      "id": "b2000000-0000-4000-8000-000000000014",
      "name": "Buscar Insights da Mídia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 320],
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Junta os dados da mídia com os insights numa linha pronta pro Postgres.\n// Se a chamada de insights falhou (post antigo demais etc.), grava a mídia com métricas nulas.\nconst midia = $('Montar Lista de Métricas').item.json;\nconst valores = {};\nfor (const m of ($json.data || [])) {\n  valores[m.name] = m.values?.[0]?.value ?? m.total_value?.value ?? null;\n}\nreturn { json: {\n  ig_media_id: midia.id,\n  media_type: midia.media_type ?? null,\n  media_product_type: midia.media_product_type ?? null,\n  caption: (midia.caption || '').slice(0, 2000),\n  permalink: midia.permalink ?? null,\n  posted_at: midia.timestamp ?? null,\n  views: valores.views ?? null,\n  reach: valores.reach ?? null,\n  likes: valores.likes ?? null,\n  comments: valores.comments ?? null,\n  saved: valores.saved ?? null,\n  shares: valores.shares ?? null,\n  total_interactions: valores.total_interactions ?? null,\n  reels_avg_watch_time_ms: valores.ig_reels_avg_watch_time ?? null,\n  raw: JSON.stringify($json.data ?? $json),\n} };"
      },
      "id": "b2000000-0000-4000-8000-000000000015",
