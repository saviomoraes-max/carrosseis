      "id": "c3000000-0000-4000-8000-000000000012",
      "name": "Buscar Trends do X",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 500],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Extrai os trending topics do X/Brasil do HTML server-rendered do getdaytrends.\nconst html = $input.first().json.data || '';\nconst achados = [...html.matchAll(/href=\"\\/brazil\\/trend\\/([^\"]+)\"[^>]*>([\\s\\S]*?)<\\/a>/g)];\nconst vistos = new Set();\nconst resultado = [];\nfor (const [, slug, texto] of achados) {\n  const titulo = texto.replace(/<[^>]*>/g, '').trim() || decodeURIComponent(slug);\n  if (!titulo || vistos.has(titulo)) continue;\n  vistos.add(titulo);\n  // slug já vem percent-encoded do href — usar cru pra não re-encodar\n  resultado.push({ json: { source: 'x_getdaytrends', title: titulo, url: `https://getdaytrends.com/brazil/trend/${slug}`, extra: null } });\n  if (resultado.length >= 20) break;\n}\nreturn resultado;"
      },
      "id": "c3000000-0000-4000-8000-000000000013",
      "name": "Extrair Trending Topics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 500]
    },
    {
      "parameters": {
        "mode": "append",
        "numberInputs": 6
      },
      "id": "c3000000-0000-4000-8000-000000000014",
      "name": "Juntar Fontes",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [840, 0]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Remove vazios e duplicatas (mesma fonte + mesmo título) antes de gravar.\nconst vistos = new Set();\nconst resultado = [];\nfor (const item of $input.all()) {\n  const titulo = (item.json.title || '').trim();\n  if (!titulo) continue;\n  const chave = `${item.json.source}::${titulo.toLowerCase()}`;\n  if (vistos.has(chave)) continue;\n  vistos.add(chave);\n  resultado.push({ json: {\n    source: item.json.source,\n    title: titulo.slice(0, 500),\n    url: item.json.url || null,\n    extra: item.json.extra ? JSON.stringify(item.json.extra) : null,\n  } });\n}\nreturn resultado;"
      },
      "id": "c3000000-0000-4000-8000-000000000015",
      "name": "Limpar e Deduplicar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 0]
