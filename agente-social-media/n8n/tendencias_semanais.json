    {
      "parameters": {
        "url": "https://trends.google.com/trending/rss?geo=BR",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "c3000000-0000-4000-8000-000000000002",
      "name": "Buscar Trends Google BR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, -500],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Parseia o RSS do Google Trends (campos no namespace ht:) sem lib externa.\n// A tag <description> vem vazia — o que interessa é title + ht:approx_traffic + ht:news_item_url.\nconst xml = $input.first().json.data || '';\nconst itens = [...xml.matchAll(/<item>([\\s\\S]*?)<\\/item>/g)];\nconst resultado = [];\nfor (const [, corpo] of itens.slice(0, 20)) {\n  const titulo = (corpo.match(/<title>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/title>/) || [])[1];\n  const trafego = (corpo.match(/<ht:approx_traffic>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/ht:approx_traffic>/) || [])[1];\n  const noticia = (corpo.match(/<ht:news_item_url>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/ht:news_item_url>/) || [])[1];\n  if (titulo) {\n    resultado.push({ json: { source: 'google_trends_br', title: titulo.trim(), url: noticia || null, extra: { trafego: trafego || null } } });\n  }\n}\nreturn resultado;"
      },
      "id": "c3000000-0000-4000-8000-000000000003",
      "name": "Extrair Termos do Trends",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, -500]
    },
    {
      "parameters": {
        "url": "https://news.google.com/rss/search?q=%22harmoniza%C3%A7%C3%A3o%20facial%22%20OR%20%22cl%C3%ADnica%20de%20est%C3%A9tica%22&hl=pt-BR&gl=BR&ceid=BR:pt-419",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "c3000000-0000-4000-8000-000000000004",
      "name": "Buscar Google News do Nicho",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, -300],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Extrai manchetes do RSS do Google News (title + link por item).\nconst xml = $input.first().json.data || '';\nconst itens = [...xml.matchAll(/<item>([\\s\\S]*?)<\\/item>/g)];\nconst resultado = [];\nfor (const [, corpo] of itens.slice(0, 15)) {\n  const titulo = (corpo.match(/<title>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/title>/) || [])[1];\n  const link = (corpo.match(/<link>(.*?)<\\/link>/) || [])[1];\n  if (titulo) {\n    resultado.push({ json: { source: 'google_news', title: titulo.trim(), url: (link || '').trim() || null, extra: null } });\n  }\n}\nreturn resultado;"
      },
      "id": "c3000000-0000-4000-8000-000000000005",
      "name": "Extrair Manchetes do Nicho",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, -300]
    },
    {
      "parameters": {
        "url": "https://g1.globo.com/rss/g1/"
      },
      "id": "c3000000-0000-4000-8000-000000000006",
      "name": "Ler RSS G1",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1,
      "position": [280, -100],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normaliza itens do G1 pro formato comum dos candidatos.\nreturn $input.all().slice(0, 15).map((i) => ({\n  json: { source: 'g1', title: i.json.title || '', url: i.json.link || null, extra: null },\n}));"
      },
